{
  "name": "roboto4ka",
  "private": true,
  "version": "1.0.0",
  "description": "Roboto4ka — десктоп-помощник для офисных задач",
  "author": "Nikita Mischenko",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k -n VITE,ELECTRON -c blue,magenta \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder --win",
    "electron:portable": "npm run build && electron-builder --win portable",
    "electron:build:mac": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "framer-motion": "^11.5.4",
    "lucide-react": "^0.460.0",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/papaparse": "^5.3.15",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.nikita.roboto4ka",
    "productName": "Roboto4ka",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "fileAssociations": [
        {
          "ext": "xlsx",
          "name": "Excel Spreadsheet",
          "description": "Открыть в Roboto4ka",
          "role": "Editor"
        },
        {
          "ext": "csv",
          "name": "CSV File",
          "description": "Открыть в Roboto4ka",
          "role": "Editor"
        },
        {
          "ext": "jpg",
          "name": "JPEG Image",
          "description": "Редактировать в Roboto4ka",
          "role": "Editor"
        },
        {
          "ext": "jpeg",
          "name": "JPEG Image",
          "description": "Редактировать в Roboto4ka",
          "role": "Editor"
        },
        {
          "ext": "png",
          "name": "PNG Image",
          "description": "Редактировать в Roboto4ka",
          "role": "Editor"
        },
        {
          "ext": "mp4",
          "name": "MP4 Video",
          "description": "Редактировать в Roboto4ka",
          "role": "Editor"
        },
        {
          "ext": "txt",
          "name": "Text File",
          "description": "Открыть в Roboto4ka",
          "role": "Editor"
        }
      ],
      "artifactName": "Roboto4ka-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Roboto4ka"
    }
  }
}
